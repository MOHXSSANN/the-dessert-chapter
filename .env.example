# ─── Square Payment Credentials ────────────────────────────────────────────
# Get these from: https://developer.squareup.com/apps → your app → Credentials

# Server-side only — NEVER expose this in the browser
SQUARE_ACCESS_TOKEN=EAAAl...your_sandbox_access_token

# Used by the client-side Square Web Payments SDK (not secret)
SQUARE_APP_ID=sandbox-sq0idb-...your_app_id
SQUARE_LOCATION_ID=...your_location_id

# Set to "production" when going live — uses live Square endpoint + live SDK URL
SQUARE_ENVIRONMENT=sandbox

# Optional: restrict payment API to your domain in production
ALLOWED_ORIGIN=https://your-domain.vercel.app
